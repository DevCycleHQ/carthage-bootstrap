{
  "name": "carthage-bootstrap",
  "version": "1.1.0",
  "packageManager": "yarn@3.6.3",
  "description": "GitHub Action that runs Carthage Bootstrap",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "prepare": "ncc build index.js -o dist --source-map --license licenses.txt",
    "test": "jest --passWithNoTests",
    "all": "npm run lint && npm run prepare && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DevCycleHQ/carthage-bootstrap.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "Xcode",
    "Carthage"
  ],
  "author": "Stefan Arentz <stefan@devbots.xyz>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DevCycleHQ/carthage-bootstrap/issues"
  },
  "homepage": "https://github.com/DevCycleHQ/carthage-bootstrap#readme",
  "dependencies": {
    "@actions/cache": "^5.0.5",
    "@actions/core": "^2.0.3",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.52.0",
    "jest": "^29.7.0"
  },
  "resolutions": {
    "cross-spawn": "^7.0.6",
    "tar": "^7.5.11",
    "minimatch@^3.0.4": "^3.1.5",
    "minimatch@^3.0.5": "^3.1.5",
    "minimatch@^3.1.1": "^3.1.5",
    "minimatch@^3.1.2": "^3.1.5",
    "minimatch@^9.0.4": "^9.0.7",
    "fast-xml-parser": "^5.5.7",
    "flatted": "^3.4.2",
    "brace-expansion@npm:^1.1.7": "^1.1.13",
    "brace-expansion@npm:^2.0.2": "^2.0.3",
    "picomatch": "^2.3.2",
    "fast-xml-builder": "^1.2.0",
    "ip-address": "^10.2.0"
  }
}
